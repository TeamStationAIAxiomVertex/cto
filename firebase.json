
{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=60, must-revalidate" }
        ]
      },
      {
        "source": "/__purge",
        "headers": [
          { "key": "Clear-Site-Data", "value": "\"cache\", \"storage\"" }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          { "key": "Cache-control", "value": "public, max-age=300, must-revalidate" }
        ]
      },
      {
        "source": "**/*.{js,css,ico,png,jpg,jpeg,gif,svg,webp,woff,woff2}",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*",
        "headers": [
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
          { "key": "X-Content-Type-Options", "value": "nosniff" }
        ]
      }
    ],
    "redirects": [
      {
        "source": "/cto-playbook",
        "destination": "/playbook/hub",
        "type": 301
      },
      {
        "source": "/playbook",
        "destination": "/playbook/hub",
        "type": 301
      },
      {
        "source": "/research",
        "destination": "/research/hub",
        "type": 301
      },
      { "source": "/privacy", "destination": "/privacy-policy", "type": 301 },
      { "source": "/terms", "destination": "/terms-of-service", "type": 301 }
    ]
  }
}
