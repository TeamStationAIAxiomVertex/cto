{
  "hosting": [
    {
      "site": "failsafe",
      "public": "failsafe",
      "ignore": ["**/.*", "**/node_modules/**"]
    },
    {
      "public": "out",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "cleanUrls": true,
      "headers": [
        {
          "source": "/_next/static/**",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|js|css)",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "public, max-age=31536000, immutable"
            }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            {
              "key": "Cache-control",
              "value": "public, max-age=0, must-revalidate"
            }
          ]
        }
      ],
      "predeploy": [
        "npm run build"
      ]
    }
  ]
}
