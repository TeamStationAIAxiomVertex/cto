{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "headers": [
      { "source": "**/*.html", "headers": [{ "key": "Cache-Control", "value": "public,max-age=60" }] },
      { "source": "**/*.{css,js}", "headers": [{ "key": "Cache-Control", "value": "public,max-age=31536000,immutable" }] }
    ]
  }
}
