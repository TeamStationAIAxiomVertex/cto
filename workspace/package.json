
{
  "name": "cto-playbook-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.19.5"
  },
  "packageManager": "npm@10.8.1",
  "scripts": {
    "dev": "next dev -p ${PORT:-8080} -H 0.0.0.0",
    "prebuild": "node scripts/preflight.cjs",
    "build": "npm run prebuild && next build",
    "start": "next start -p ${PORT:-8080} -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "postinstall": "node -e \"if(process.env.CI || process.env.FIREBASE_CONFIG) require('./scripts/preflight.cjs')\""
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "class-variance-authority": "^0.7.0",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.379.0",
    "next": "14.2.3",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.3.0",
    "postcss": "^8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.12.7",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "server-only": "^0.0.1",
