    "@types/react-dom": "^18",
    "@types/recharts": "^1.8.29",
    "cheerio": "^1.0.0-rc.12",
    "critters": "^0.0.23",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.3",
    "fast-glob": "^3.3.2",
    "kleur": "^4.1.5",
    "linkinator": "^4.0.0",
    "typescript": "^5",
    "globby": "^14.0.1"
