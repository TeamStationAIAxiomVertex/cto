{
  "hosting": {
    "source": ".",
    "rewrites": [
      { "source": "**", "run": { "serviceId": "web", "region": "us-central1" } }
    ]
  },
  "apphosting": {
    "targets": {
      "web": {
        "runtime": { "node": "20.19.0" },
        "buildCommand": "npm run build:production",
        "runCommand": "npm run start",
        "healthCheck": { "path": "/healthz", "timeoutSeconds": 30 }
      }
    }
  }
}