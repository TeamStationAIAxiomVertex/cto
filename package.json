    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.379.0",
    "next": "14.2.3",
    "next-pwa": "^5.6.0",
    "next-themes": "^0.3.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.12.7",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
