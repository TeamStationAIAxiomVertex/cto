{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@/components/Tooltip",
            "message": "Import from '@/components/ui/tooltip' instead."
          }
        ],
        "patterns": [
          {
            "group": ["**/components/Tooltip"],
            "message": "Use '@/components/ui/tooltip'."
          },
          {
            "group": ["@/components/client/*"],
            "message": "Do not statically import client islands into server files. Use dynamic(() => import(...), { ssr:false }) or pass as children."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/lib/**", "src/components/**"],
      "rules": {
        "no-restricted-syntax": [
          "warn",
          {
            "selector": "Program:has(Directive[value='use client'])",
            "message": "'use client' not allowed here. Move to src/components/client/** or create a client island."
          }
        ]
      }
    }
  ]
}
